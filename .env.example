# App
DEBUG=false
SECRET_KEY=change-me-to-random-64-char-hex-string
ALLOWED_ORIGINS=["http://localhost:5173"]

# Database
POSTGRES_DB=training_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/training_platform

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption key for OAuth tokens (32 bytes = 64 hex chars)
ENCRYPTION_KEY=change-me-to-random-64-char-hex-string

# External integrations (fill in Этапе 4)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=
